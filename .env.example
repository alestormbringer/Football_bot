# Football AI Bot — Environment Variables
# Copia questo file in .env e compila i valori reali
# NON committare mai .env

# API-Football (https://dashboard.api-football.com)
API_FOOTBALL_KEY=your_api_football_key_here

# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_key_here

# Telegram Bot (da @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Stagione calcistica corrente (anno di inizio, es. 2025 = stagione 2025/26)
# Usata per campionati nazionali e coppe club.
# Per i tornei internazionali (Mondiali, Euro, Nations League) il codice
# usa automaticamente l'anno solare corrente — non serve cambiare qui.
CURRENT_SEASON=2025
